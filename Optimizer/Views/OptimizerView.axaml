<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:SE2.ViewModels"
             xmlns:c= "using:SE2.Views"
             xmlns:lvc="using:LiveChartsCore.SkiaSharpView.Avalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="SE2.Views.OptimizerView"
             x:DataType="vm:OptimizerViewModel">
    <UserControl.Styles>
        <Style Selector="Button.Button">
            <Setter Property="Padding" Value="14,8,14,8"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#ED071B"/>

            <Style Selector="^ /template/ ContentPresenter#PART_ContentPresenter">
                <Setter Property="RecognizesAccessKey" Value="True" />
            </Style>

            <Style Selector="^:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                <Setter Property="Foreground" Value="#FFFFFF"/>
                <Setter Property="Background" Value="#CF0416"/>
            </Style>

            <Style Selector="^:pressed">
                <Setter Property="RenderTransform" Value="scale(0.98)" />
            </Style>

            <Style Selector="^:pressed  /template/ ContentPresenter#PART_ContentPresenter">
                <Setter Property="Foreground" Value="#FFFFFF"/>
                <Setter Property="Background" Value="#A3000E"/>
            </Style>
        </Style>
        <Style Selector="TextBlock.Subheading">
            <Setter Property="Foreground" Value="#697077"/>
        </Style>
        <Style Selector="TextBlock.Heading">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Foreground" Value="#21272A"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Border.RedBorder">
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="BorderBrush" Value="#ED071B"/>
            <Setter Property="Padding" Value="4"/>
        </Style>
    </UserControl.Styles>
    <StackPanel Spacing="12">
        <StackPanel Orientation="Horizontal" Spacing="12">
            <Button Name="OptimizerBtn"
                    Classes="Button"
                    Content="Run optimization"
                    IsEnabled="{Binding RunEnabled}"
                    Command="{Binding RunOptimizationCommand}"/>
            <Button Name="ExportBtn"
                    Classes= "Button"
                    Content= "Export"
                    IsEnabled="{Binding ExportEnabled}"
                    Command="{Binding ExportCommand}"/>
        </StackPanel>
        <TextBlock Classes="Heading" Text="Optimization results"/>
        <Grid ColumnDefinitions="* * * * * * *" HorizontalAlignment= "Stretch">
            <Border Grid.Column="0" Classes="RedBorder">
                <StackPanel Margin="4"  Spacing="4">
                    <TextBlock Classes="Subheading"  Text="Total Profit"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Classes="Heading" Text="{Binding TotalProfit, StringFormat={}{0:n0}}"/>
                        <TextBlock Classes="Heading" Text=" DKK"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Classes="RedBorder">
                <StackPanel Margin="4" Spacing="4">
                    <TextBlock Text="Total Expenses"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Classes="Heading" Text="{Binding TotalCost, StringFormat={}{0:n0}}"/>
                        <TextBlock Classes="Heading" Text=" DKK"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Classes="RedBorder">
                <StackPanel Margin="4" Spacing="4">
                    <TextBlock Text="Heat Produced"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Classes="Heading" Text="{Binding HeatProduced, StringFormat={}{0:n0}}"/>
                        <TextBlock Classes="Heading" Text=" MWh"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            <Border Grid.Column="3" Classes="RedBorder">
                <StackPanel Margin="4"  Spacing="4">
                    <TextBlock Text="Electricity Consumed"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Classes="Heading" Text="{Binding ElectricityConsumed, StringFormat={}{0:n0}}"/>
                        <TextBlock Classes="Heading" Text=" MWh"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            <Border Grid.Column="4" Classes="RedBorder">
                <StackPanel Margin="4" Spacing="4">
                    <TextBlock Text="Electricity Produced"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Classes="Heading" Text="{Binding ElectricityProduced, StringFormat={}{0:n0}}"/>
                        <TextBlock Classes="Heading" Text=" MWh"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            <Border Grid.Column="5" Classes="RedBorder">
                <StackPanel Margin="4" Spacing="4">
                    <TextBlock Text="Primary Energy"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Classes="Heading" Text="{Binding PrimaryEnergy, StringFormat={}{0:n0}}"/>
                        <TextBlock Classes="Heading" Text=" MWh"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            <Border Grid.Column="6" Classes="RedBorder">
                <StackPanel Margin="4" Spacing= "4">
                    <TextBlock Text="CO2 Emissions"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Classes="Heading" Text="{Binding Co2Emissions, StringFormat={}{0:n0}}"/>
                        <TextBlock Classes="Heading" Text=" kg CO2"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
        <TextBlock Text="{Binding MaintenanceText}" />
        <ComboBox Name="ProductionUnitsComboBox"
                  SelectedIndex="0"
                  MaxDropDownHeight="100"
                  ItemsSource="{Binding ProductionUnits}" SelectionChanged="SelectionChanged"
                  SelectedItem="{Binding SelectedProductionUnit}" />
        <Grid  Name="ChartGrid"
               ColumnSpacing="20"
               RowSpacing="20"
               ColumnDefinitions="*,*"
               RowDefinitions="*,*,*,*,*,*"/>
    </StackPanel>
</UserControl>