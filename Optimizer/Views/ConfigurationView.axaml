<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:SE2.ViewModels"
             mc:Ignorable="d" 
             d:DesignWidth="800" 
             d:DesignHeight="450"
             x:Class="SE2.Views.ConfigurationView"
             x:DataType="vm:ConfigurationViewModel">     

    <UserControl.DataContext>
        <vm:ConfigurationViewModel/>
    </UserControl.DataContext>
    
    <UserControl.Styles>
        <Style Selector="TextBlock.Heading">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Foreground" Value="#21272A"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style Selector="TextBlock.Subheading">
            <Setter Property="Foreground" Value="#697077"/>
        </Style>
    </UserControl.Styles>

    <StackPanel Orientation="Vertical" Spacing="24">

        <!-- Production Units -->
        <TextBlock Classes="Heading" 
                   Text="Allowed maintenance production units"/>

        <WrapPanel Orientation="Horizontal" 
                   ItemSpacing="12"
                   ItemWidth="210">

            <ComboBox 
                ItemsSource="{Binding ProductionUnits}"
                SelectedItem="{Binding SelectedProductionUnit}"
                PlaceholderText="Select production unit..."
                MaxDropDownHeight="100">

                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>

            </ComboBox>
        </WrapPanel>    

        <!-- Maintenance Period -->
        <TextBlock Classes="Heading" Text="Maintenance period"/>

        <StackPanel Orientation="Horizontal"
                    Spacing="12">

            <TextBlock Classes="Heading" Text="From"/>

            <TextBox Width="210"
                     Text="{Binding MaintenanceFrom, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                     Watermark="From"/>  

            <TextBlock Classes="Heading" Text="to"/>

            <TextBox Width="210"
                     Text="{Binding MaintenanceTo, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                     Watermark="To"/>

            <TextBlock Classes="Heading" Text="hours"/>
        </StackPanel>

        <!-- Priority -->
        <TextBlock Classes="Heading" Text="Priority"/>

        <ComboBox 
            ItemsSource="{Binding Priorities}"
            SelectedItem="{Binding SelectedPriority}"
            PlaceholderText="Select priority..."
            Width="210">

            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding}" />
                </DataTemplate>
            </ComboBox.ItemTemplate>

        </ComboBox>
        <!-- Save Button -->
        <Button Content="Save"
                Command="{Binding SaveConfigurationCommand}"
                Width="120"/>

    </StackPanel>
</UserControl>