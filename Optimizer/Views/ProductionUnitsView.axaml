<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:SE2.ViewModels"
             xmlns:models="using:SE2.Models"
             xmlns:dialogHostAvalonia="clr-namespace:DialogHostAvalonia;assembly=DialogHost.Avalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="SE2.Views.ProductionUnitsView"
             x:DataType="vm:ProductionUnitsViewModel">

    <UserControl.Resources>

        <ControlTheme x:Key="ConfirmButton" TargetType="Button">
            <Setter Property="Background" Value="#0f62fe"/>
            <Setter Property="Foreground" Value="#ffffff"/>
            <Setter Property="Padding" Value="14,8,14,8"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Style Selector="^:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                <Setter Property="Background" Value="#1155d5"/>
                <Setter Property="Foreground" Value="#ffffff"/>
            </Style>
            <Style Selector="^:pressed /template/ ContentPresenter#PART_ContentPresenter">
                <Setter Property="Background" Value="#093c9a"/>
                <Setter Property="Foreground" Value="#ffffff"/>
            </Style>
        </ControlTheme>

    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="CheckBox:checked /template/ Border#NormalRectangle">
            <Setter Property="Background" Value="#0f62fe"/>
        </Style>
    </UserControl.Styles>

    <StackPanel>
        <Border Background="#f2f4f8" CornerRadius="0" Margin="0,10,0,0"
                BorderBrush="#dde1e6" BorderThickness="2"
                Padding="5" >
            <Grid ColumnDefinitions="*,2*,13*,*" ColumnSpacing="20">
                <CheckBox Grid.Row="0" Grid.Column="0" CornerRadius="0" BorderThickness="2" IsChecked="{Binding SelectAll}"></CheckBox>
                <TextBlock FontWeight="Bold" Grid.Row="0" Grid.Column="1"
                           Text="Production unit" VerticalAlignment="Center"/>
                <UniformGrid Grid.Row="0" Grid.Column="2" Rows="1" ColumnSpacing="5">
                    <TextBlock Margin="5" FontWeight="Bold"
                               Text="Net costs" VerticalAlignment="Center"/>
                    <TextBlock Margin="5" FontWeight="Bold"
                               Text="Heat production" VerticalAlignment="Center"/>
                    <TextBlock Margin="5" FontWeight="Bold"
                               Text="Electricity" VerticalAlignment="Center"/>
                    <TextBlock Margin="5" FontWeight="Bold"
                               Text="Gas Usages" VerticalAlignment="Center"/>
                    <TextBlock Margin="5" FontWeight="Bold"
                               Text="Oil Usages" VerticalAlignment="Center"/>
                    <TextBlock Margin="5" FontWeight="Bold"
                               Text="Emissions" VerticalAlignment="Center"/>
                </UniformGrid>
            </Grid>
        </Border>

        <!-- Binding to observable Production Unit Collection -->
        <ItemsControl ItemsSource="{Binding ProductionUnits}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border CornerRadius="0" Margin="0,-2,0,0"
                            BorderBrush="#dde1e6" BorderThickness="2"
                            Padding="5">
                        <Grid ColumnDefinitions="*,2*,13*,*" ColumnSpacing="20">
                            <CheckBox Grid.Row="0" Grid.Column="0" CornerRadius="0" BorderThickness="2" IsChecked="{Binding IsSelected, Mode=TwoWay}"></CheckBox>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center"/>
                            <UniformGrid Grid.Row="0" Grid.Column="2" Rows="1" ColumnSpacing="5">
                                <TextBlock Margin="5" VerticalAlignment="Center">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat= '{}{0} DKK / MWh'>
                                            <Binding Path="ProductionCosts" />
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                                <TextBlock Margin="5" VerticalAlignment="Center">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat= '{}{0} MW'>
                                            <Binding Path="MaxHeat" />
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                                <TextBlock Margin="5" VerticalAlignment="Center">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat= '{}{0} MW'>
                                            <Binding Path="MaxElectricity" />
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                                <TextBlock Margin="5" VerticalAlignment="Center">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat= '{}{0} MWh'>
                                            <Binding Path="GasConsumption" />
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                                <TextBlock Margin="5" VerticalAlignment="Center">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat= '{}{0} MWh'>
                                            <Binding Path="OilConsumption" />
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                                <TextBlock Margin="5" VerticalAlignment="Center">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat= '{}{0} kg / MWh'>
                                            <Binding Path="Co2Emissions" />
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </UniformGrid>
                            <Button Grid.Row="0" Grid.Column="3" Background="Transparent" HorizontalAlignment="Right" Command="{Binding OpenEditUnitMenu}">
                                <TextBlock Text="&#xf304;" FontFamily="{StaticResource FontAwesome}" FontSize="20"/>
                            </Button>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        <Button x:Name ="AddButton" Theme="{StaticResource ConfirmButton}" Content="Add production unit" HorizontalAlignment="Left" Command="{Binding OpenAddUnitMenu}" Margin="20 10"/>
    </StackPanel>

</UserControl>