<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:SE2.ViewModels"
             xmlns:models="using:SE2.Models"
             xmlns:dialogHostAvalonia="clr-namespace:DialogHostAvalonia;assembly=DialogHost.Avalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="SE2.Views.ProductionUnitsView"
             x:DataType="vm:ProductionUnitsViewModel">


    <UserControl.Styles>
        <Style Selector="Button.Confirm">
            <Setter Property="Background" Value="#0f62fe"/>
            <Setter Property="Foreground" Value="#ffffff"/>
            <Setter Property="Padding" Value="14,8,14,8"/>
        </Style>
        <Style Selector="Button.Cancel">
            <Setter Property="Background" Value="#da1e28"/>
            <Setter Property="Foreground" Value="#ffffff"/>
            <Setter Property="Padding" Value="14,8,14,8"/>
        </Style>
        <Style Selector="Button.Confirm:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#1155d5"/>
            <Setter Property="Foreground" Value="#ffffff"/>
        </Style>
        <Style Selector="Button.Confirm:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#093c9a"/>
            <Setter Property="Foreground" Value="#ffffff"/>
        </Style>
    </UserControl.Styles>


    <UserControl.DataTemplates>
        <DataTemplate DataType="models:ProductionUnitsModel">
            <StackPanel Orientation="Horizontal">
                <Border Background="#f2f4f8" CornerRadius="0" Margin="0,10,0,0"
                        BorderBrush="#dde1e6" BorderThickness="2"
                        Padding="5" >
                        <Grid RowDefinitions="* * * * * * * *"></Grid>
                </Border>
            </StackPanel>
        </DataTemplate>
    </UserControl.DataTemplates>

    <UserControl.Resources>
        <Border x:Key="EditProductionUnitView" CornerRadius="8" Margin="0,0,0,0"
                Background="#ffffff"
                BorderBrush="#ffffff" BorderThickness="2"
                Padding="5">
            <StackPanel Height="360" Width="360" VerticalAlignment="Center">
                <Button HorizontalAlignment="Right" Command="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=dialogHostAvalonia:DialogHost}, Path=CloseDialogCommand}">
                    <TextBlock Text="&#xf00d;" FontFamily="{StaticResource FontAwesome}" FontSize="20" />
                </Button>
                <Button x:Name ="SaveButton" Classes="Confirm" Content="Save" Margin="20 10"></Button>
            </StackPanel>
        </Border>
    </UserControl.Resources>

    <StackPanel>
        <Border Background="#f2f4f8" CornerRadius="0" Margin="0,10,0,0"
                BorderBrush="#dde1e6" BorderThickness="2"
                Padding="5" >
            <Grid ColumnDefinitions="*,2*,13*,*" ColumnSpacing="20">
                <CheckBox Grid.Row="0" Grid.Column="0" CornerRadius="0" BorderThickness="2" IsChecked=""></CheckBox>
                <TextBlock FontWeight="Bold" Grid.Row="0" Grid.Column="1"
                           Text="Production unit" VerticalAlignment="Center"/>
                <UniformGrid Grid.Row="0" Grid.Column="2" Rows="1" ColumnSpacing="5">
                    <TextBlock Margin="5" FontWeight="Bold"
                               Text="Net production costs" VerticalAlignment="Center"/>
                    <TextBlock Margin="5" FontWeight="Bold"
                               Text="Heat production costs" VerticalAlignment="Center"/>
                    <TextBlock Margin="5" FontWeight="Bold"
                               Text="Electricity costs" VerticalAlignment="Center"/>
                    <TextBlock Margin="5" FontWeight="Bold"
                               Text="Electricity sales" VerticalAlignment="Center"/>
                </UniformGrid>
            </Grid>
        </Border>
        <ItemsControl ItemsSource="{Binding ProductionUnits}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border CornerRadius="0" Margin="0,-2,0,0"
                            BorderBrush="#dde1e6" BorderThickness="2"
                            Padding="5">
                        <Grid ColumnDefinitions="*,2*,13*,*" ColumnSpacing="20">
                            <CheckBox Grid.Row="0" Grid.Column="0" CornerRadius="0" BorderThickness="2" IsChecked="{Binding IsSelected}"></CheckBox>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center"/>
                            <UniformGrid Grid.Row="0" Grid.Column="2" Rows="1" ColumnSpacing="5">
                                <TextBlock Margin="5"
                                           Text="{Binding NetCost}" VerticalAlignment="Center"/>
                                <TextBlock Margin="5"
                                           Text="{Binding HeatCost}" VerticalAlignment="Center"/>
                                <TextBlock Margin="5"
                                           Text="{Binding ElectricityCost}" VerticalAlignment="Center"/>
                                <TextBlock Margin="5"
                                           Text="{Binding ElectricitySales}" VerticalAlignment="Center"/>
                            </UniformGrid>
                            <Button Grid.Row="0" Grid.Column="3" HorizontalAlignment="Right" Click="OpenEditUnitMenu">
                                <TextBlock Text="&#xf304;" FontFamily="{StaticResource FontAwesome}" FontSize="20"/>
                            </Button>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        <Button x:Name ="AddButton" Classes="Confirm" Content="Add production unit" Margin="20 10">
        </Button>
    </StackPanel>

</UserControl>