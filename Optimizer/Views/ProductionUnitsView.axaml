<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:SE2.ViewModels"
             xmlns:models="using:SE2.Models"
             xmlns:dialogHostAvalonia="clr-namespace:DialogHostAvalonia;assembly=DialogHost.Avalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="SE2.Views.ProductionUnitsView"
             x:DataType="vm:ProductionUnitsViewModel">

    <UserControl.Resources>

        <ControlTheme x:Key="Heading" TargetType="TextBlock">
            <Setter Property="FontSize" Value="26"/>
            <Setter Property="Foreground" Value="#21272A"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </ControlTheme>

        <ControlTheme x:Key="ConfirmButton" TargetType="Button">
            <Setter Property="Background" Value="#0f62fe"/>
            <Setter Property="Foreground" Value="#ffffff"/>
            <Setter Property="Padding" Value="14,8,14,8"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Style Selector="^:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                <Setter Property="Background" Value="#1155d5"/>
                <Setter Property="Foreground" Value="#ffffff"/>
            </Style>
            <Style Selector="^:pressed /template/ ContentPresenter#PART_ContentPresenter">
                <Setter Property="Background" Value="#093c9a"/>
                <Setter Property="Foreground" Value="#ffffff"/>
            </Style>
        </ControlTheme>

        <ControlTheme x:Key="CancelButton" TargetType="Button">
            <Setter Property="Background" Value="#da1e28"/>
            <Setter Property="Foreground" Value="#ffffff"/>
            <Setter Property="Padding" Value="14,8,14,8"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Style Selector="^:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                <Setter Property="Background" Value="#cf1e26"/>
                <Setter Property="Foreground" Value="#ffffff"/>
            </Style>
            <Style Selector="^:pressed /template/ ContentPresenter#PART_ContentPresenter">
                <Setter Property="Background" Value="#b51920"/>
                <Setter Property="Foreground" Value="#ffffff"/>
            </Style>
        </ControlTheme>







        <StackPanel x:Key="EditProductionUnitView" Height="480" Width="560" VerticalAlignment="Center">
            <Panel Margin="0,10,0,0">
                <TextBlock Theme="{StaticResource Heading}" HorizontalAlignment="Center" TextAlignment="Center">Edit production unit</TextBlock>
                <Button HorizontalAlignment="Right" Command="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=dialogHostAvalonia:DialogHost}, Path=CloseDialogCommand}">
                    <TextBlock Text="&#xf00d;" FontFamily="{StaticResource FontAwesome}" FontSize="20" />
                </Button>
            </Panel>
            <ContentControl Content="{Binding SelectedProductionUnit}">
                <ContentControl.ContentTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Border Background="#f2f4f8" CornerRadius="0" Margin="0,10,0,0"
                                    BorderBrush="#dde1e6" BorderThickness="2"
                                    Padding="5" >
                                <UniformGrid Columns="1" Rows="8" RowSpacing="10">
                                    <TextBlock Margin="5"
                                               Text="Production Unit" />
                                    <TextBlock Margin="5"
                                               Text="Unit Type" />
                                    <TextBlock Margin="5"
                                               Text="Production Costs" />
                                    <TextBlock Margin="5"
                                               Text="Gas Consumption" />
                                    <TextBlock Margin="5"
                                               Text="Electricity Consumption" />
                                    <TextBlock Margin="5"
                                               Text="Electricity Production" />
                                    <TextBlock Margin="5"
                                               Text="Max operation point" />
                                    <TextBlock Margin="5"
                                               Text="CO2 Emissions" />
                                </UniformGrid>
                            </Border>
                            <Border CornerRadius="0" Margin="-2,10,0,0"
                                    BorderBrush="#dde1e6" BorderThickness="2"
                                    Padding="5" >
                                <UniformGrid Columns="1" Rows="8" RowSpacing="10">
                                    <TextBlock Margin="5"
                                               Text="Production Unit" />
                                    <ComboBox Margin="0" BorderThickness="0" HorizontalAlignment="Stretch"/>
                                    <TextBlock Margin="5"
                                               Text="Production Costs" />
                                    <TextBlock Margin="5"
                                               Text="Gas Consumption" />
                                    <TextBlock Margin="5"
                                               Text="Electricity Consumption" />
                                    <TextBlock Margin="5"
                                               Text="Electricity Production" />
                                    <TextBlock Margin="5"
                                               Text="Max operation point" />
                                    <TextBlock Margin="5"
                                               Text="CO2 Emissions" />
                                </UniformGrid>
                            </Border>
                        </StackPanel>
                    </DataTemplate>
                </ContentControl.ContentTemplate>
            </ContentControl>
            <UniformGrid Rows="1" Columns="2">
                <Button x:Name ="DeleteButton" Theme="{StaticResource CancelButton}" Content="Delete production unit" HorizontalAlignment="Left" Margin="20 20"/>
                <Button x:Name ="SaveButton" Theme="{StaticResource ConfirmButton}" Content="Save" HorizontalAlignment="Right" Margin="20 20"/>
            </UniformGrid>
        </StackPanel>



    </UserControl.Resources>

    <StackPanel>
        <Border Background="#f2f4f8" CornerRadius="0" Margin="0,10,0,0"
                BorderBrush="#dde1e6" BorderThickness="2"
                Padding="5" >
            <Grid ColumnDefinitions="*,2*,13*,*" ColumnSpacing="20">
                <CheckBox Grid.Row="0" Grid.Column="0" CornerRadius="0" BorderThickness="2" IsChecked=""></CheckBox>
                <TextBlock FontWeight="Bold" Grid.Row="0" Grid.Column="1"
                           Text="Production unit" VerticalAlignment="Center"/>
                <UniformGrid Grid.Row="0" Grid.Column="2" Rows="1" ColumnSpacing="5">
                    <TextBlock Margin="5" FontWeight="Bold"
                               Text="Net production costs" VerticalAlignment="Center"/>
                    <TextBlock Margin="5" FontWeight="Bold"
                               Text="Heat production costs" VerticalAlignment="Center"/>
                    <TextBlock Margin="5" FontWeight="Bold"
                               Text="Electricity costs" VerticalAlignment="Center"/>
                    <TextBlock Margin="5" FontWeight="Bold"
                               Text="Electricity sales" VerticalAlignment="Center"/>
                </UniformGrid>
            </Grid>
        </Border>
        <ItemsControl ItemsSource="{Binding ProductionUnits}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border CornerRadius="0" Margin="0,-2,0,0"
                            BorderBrush="#dde1e6" BorderThickness="2"
                            Padding="5">
                        <Grid ColumnDefinitions="*,2*,13*,*" ColumnSpacing="20">
                            <CheckBox Grid.Row="0" Grid.Column="0" CornerRadius="0" BorderThickness="2" IsChecked="{Binding IsSelected}"></CheckBox>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center"/>
                            <UniformGrid Grid.Row="0" Grid.Column="2" Rows="1" ColumnSpacing="5">
                                <TextBlock Margin="5"
                                           Text="{Binding NetCost}" VerticalAlignment="Center"/>
                                <TextBlock Margin="5"
                                           Text="{Binding HeatCost}" VerticalAlignment="Center"/>
                                <TextBlock Margin="5"
                                           Text="{Binding ElectricityCost}" VerticalAlignment="Center"/>
                                <TextBlock Margin="5"
                                           Text="{Binding ElectricitySales}" VerticalAlignment="Center"/>
                            </UniformGrid>
                            <Button Grid.Row="0" Grid.Column="3" HorizontalAlignment="Right" Click="OpenEditUnitMenu">
                                <TextBlock Text="&#xf304;" FontFamily="{StaticResource FontAwesome}" FontSize="20"/>
                            </Button>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        <Button x:Name ="AddButton" Theme="{StaticResource ConfirmButton}" Content="Add production unit" HorizontalAlignment="Left" Margin="20 10"/>
    </StackPanel>

</UserControl>