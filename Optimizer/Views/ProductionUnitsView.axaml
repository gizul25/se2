<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:SE2.ViewModels"
             xmlns:models="using:SE2.Models"
             xmlns:dialogHostAvalonia="clr-namespace:DialogHostAvalonia;assembly=DialogHost.Avalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="SE2.Views.ProductionUnitsView"
             x:DataType="vm:ProductionUnitsViewModel">

    <UserControl.Resources>

        <ControlTheme x:Key="Heading" TargetType="TextBlock">
            <Setter Property="FontSize" Value="26"/>
            <Setter Property="Foreground" Value="#21272A"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </ControlTheme>

        <ControlTheme x:Key="ConfirmButton" TargetType="Button">
            <Setter Property="Background" Value="#0f62fe"/>
            <Setter Property="Foreground" Value="#ffffff"/>
            <Setter Property="Padding" Value="14,8,14,8"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Style Selector="^:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                <Setter Property="Background" Value="#1155d5"/>
                <Setter Property="Foreground" Value="#ffffff"/>
            </Style>
            <Style Selector="^:pressed /template/ ContentPresenter#PART_ContentPresenter">
                <Setter Property="Background" Value="#093c9a"/>
                <Setter Property="Foreground" Value="#ffffff"/>
            </Style>
        </ControlTheme>

        <ControlTheme x:Key="CancelButton" TargetType="Button">
            <Setter Property="Background" Value="#da1e28"/>
            <Setter Property="Foreground" Value="#ffffff"/>
            <Setter Property="Padding" Value="14,8,14,8"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Style Selector="^:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                <Setter Property="Background" Value="#cf1e26"/>
                <Setter Property="Foreground" Value="#ffffff"/>
            </Style>
            <Style Selector="^:pressed /template/ ContentPresenter#PART_ContentPresenter">
                <Setter Property="Background" Value="#b51920"/>
                <Setter Property="Foreground" Value="#ffffff"/>
            </Style>
        </ControlTheme>



        <!-- Edit view for Production Units -->
        <StackPanel x:Key="EditProductionUnitView" Height="500" Width="560" VerticalAlignment="Center">
            <Panel Margin="0,10,0,10">
                <TextBlock x:Name="Heading" Theme="{StaticResource Heading}" HorizontalAlignment="Center" TextAlignment="Center" Text="Edit production unit"/>
                <Button HorizontalAlignment="Right" Background="Transparent" Command="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=dialogHostAvalonia:DialogHost}, Path=CloseDialogCommand}">
                    <TextBlock Text="&#xf00d;" FontFamily="{StaticResource FontAwesome}" FontSize="20" />
                </Button>
            </Panel>
            <ContentControl Content="{Binding SelectedProductionUnit}">
                <ContentControl.ContentTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Border Background="#f2f4f8" CornerRadius="0" Margin="-2,10,0,0"
                                    BorderBrush="#dde1e6" BorderThickness="2">
                                <UniformGrid Width="230" Columns="1" Rows="8" RowSpacing="0">
                                    <!-- Placeholder, should be binded to selected production unit data -->
                                    <Border BorderBrush="#dde1e6" BorderThickness="2" Margin="-2,-2,-2,0" Padding="5"> <TextBlock Margin="5" VerticalAlignment="Center" FontWeight="SemiBold" Text="Production Unit" /> </Border>
                                    <Border BorderBrush="#dde1e6" BorderThickness="2" Margin="-2,-2,-2,0" Padding="5"> <TextBlock Margin="5" VerticalAlignment="Center" FontWeight="SemiBold" Text="Unit Type" /> </Border>
                                    <Border BorderBrush="#dde1e6" BorderThickness="2" Margin="-2,-2,-2,0" Padding="5"> <TextBlock Margin="5" VerticalAlignment="Center" FontWeight="SemiBold" Text="Production Costs" /> </Border>
                                    <Border BorderBrush="#dde1e6" BorderThickness="2" Margin="-2,-2,-2,0" Padding="5"> <TextBlock Margin="5" VerticalAlignment="Center" FontWeight="SemiBold" Text="Gas Consumption" /> </Border>
                                    <Border BorderBrush="#dde1e6" BorderThickness="2" Margin="-2,-2,-2,0" Padding="5"> <TextBlock Margin="5" VerticalAlignment="Center" FontWeight="SemiBold" Text="Electricity Consumption" /> </Border>
                                    <Border BorderBrush="#dde1e6" BorderThickness="2" Margin="-2,-2,-2,0" Padding="5"> <TextBlock Margin="5" VerticalAlignment="Center" FontWeight="SemiBold" Text="Electricity Production" /> </Border>
                                    <Border BorderBrush="#dde1e6" BorderThickness="2" Margin="-2,-2,-2,0" Padding="5"> <TextBlock Margin="5" VerticalAlignment="Center" FontWeight="SemiBold" Text="Max operation point" /> </Border>
                                    <Border BorderBrush="#dde1e6" BorderThickness="2" Margin="-2,-2,-2,-2" Padding="5"> <TextBlock Margin="5" VerticalAlignment="Center" FontWeight="SemiBold" Text="CO2 Emissions" /> </Border>
                                </UniformGrid>
                            </Border>
                            <Border CornerRadius="0" Margin="-2,10,0,0"
                                    BorderBrush="#dde1e6" BorderThickness="2">
                                <UniformGrid Width="230" Columns="1" Rows="8" RowSpacing="0">
                                    <Border BorderBrush="#dde1e6" BorderThickness="2" Margin="-2,-2,-2,0"> <TextBox Margin="5" BorderThickness="0" VerticalAlignment="Center" /> </Border>
                                    <Border BorderBrush="#dde1e6" BorderThickness="2" Margin="-2,-2,-2,0" Padding="5"> <ComboBox Margin="0" BorderThickness="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/> </Border>
                                    <Border BorderBrush="#dde1e6" BorderThickness="2" Margin="-2,-2,-2,0" Padding="5"> <TextBox Margin="0" BorderThickness="0" VerticalAlignment="Center" /> </Border>
                                    <Border BorderBrush="#dde1e6" BorderThickness="2" Margin="-2,-2,-2,0" Padding="5"> <TextBox Margin="0" BorderThickness="0" VerticalAlignment="Center"  /> </Border>
                                    <Border BorderBrush="#dde1e6" BorderThickness="2" Margin="-2,-2,-2,0" Padding="5"> <TextBox Margin="0" BorderThickness="0" VerticalAlignment="Center" /> </Border>
                                    <Border BorderBrush="#dde1e6" BorderThickness="2" Margin="-2,-2,-2,0" Padding="5"> <TextBox Margin="0" BorderThickness="0" VerticalAlignment="Center" /> </Border>
                                    <Border BorderBrush="#dde1e6" BorderThickness="2" Margin="-2,-2,-2,0" Padding="5"> <TextBox Margin="0" BorderThickness="0" VerticalAlignment="Center" /> </Border>
                                    <Border BorderBrush="#dde1e6" BorderThickness="2" Margin="-2,-2,-2,-2" Padding="5"> <TextBox Margin="0" BorderThickness="0" VerticalAlignment="Center" /> </Border>
                                </UniformGrid>
                            </Border>
                        </StackPanel>
                    </DataTemplate>
                </ContentControl.ContentTemplate>
            </ContentControl>
            <UniformGrid Rows="1" Columns="2">
                <Button x:Name ="DeleteButton" Theme="{StaticResource CancelButton}" Content="Delete production unit" HorizontalAlignment="Left" Margin="43 20"/>
                <Button x:Name ="SaveButton" Theme="{StaticResource ConfirmButton}" Content="Save" HorizontalAlignment="Right" Margin="47 20"/>
            </UniformGrid>
        </StackPanel>



    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="CheckBox:checked /template/ Border#NormalRectangle">
            <Setter Property="Background" Value="#0f62fe"/>
        </Style>
    </UserControl.Styles>

    <StackPanel>
        <Border Background="#f2f4f8" CornerRadius="0" Margin="0,10,0,0"
                BorderBrush="#dde1e6" BorderThickness="2"
                Padding="5" >
            <Grid ColumnDefinitions="*,2*,13*,*" ColumnSpacing="20">
                <CheckBox Grid.Row="0" Grid.Column="0" CornerRadius="0" BorderThickness="2" IsChecked="{Binding SelectAll}"></CheckBox>
                <TextBlock FontWeight="Bold" Grid.Row="0" Grid.Column="1"
                           Text="Production unit" VerticalAlignment="Center"/>
                <UniformGrid Grid.Row="0" Grid.Column="2" Rows="1" ColumnSpacing="5">
                    <TextBlock Margin="5" FontWeight="Bold"
                               Text="Net production costs" VerticalAlignment="Center"/>
                    <TextBlock Margin="5" FontWeight="Bold"
                               Text="Heat production costs" VerticalAlignment="Center"/>
                    <TextBlock Margin="5" FontWeight="Bold"
                               Text="Electricity costs" VerticalAlignment="Center"/>
                    <TextBlock Margin="5" FontWeight="Bold"
                               Text="Electricity sales" VerticalAlignment="Center"/>
                </UniformGrid>
            </Grid>
        </Border>

        <!-- Binding to observable Production Unit Collection -->
        <ItemsControl ItemsSource="{Binding ProductionUnits}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border CornerRadius="0" Margin="0,-2,0,0"
                            BorderBrush="#dde1e6" BorderThickness="2"
                            Padding="5">
                        <Grid ColumnDefinitions="*,2*,13*,*" ColumnSpacing="20">
                            <CheckBox Grid.Row="0" Grid.Column="0" CornerRadius="0" BorderThickness="2" IsChecked="{Binding IsSelected, Mode=TwoWay}"></CheckBox>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center"/>
                            <UniformGrid Grid.Row="0" Grid.Column="2" Rows="1" ColumnSpacing="5">
                                <TextBlock Margin="5" VerticalAlignment="Center">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat= '{}{0} kr    {1} kr'>
                                            <!-- Normal Value -->
                                            <Binding Path="NetCostNormal" />
                                            <!-- Optimized Value -->
                                            <Binding Path="NetCostOptimized" />
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                                <TextBlock Margin="5" VerticalAlignment="Center">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat= '{}{0} kr    {1} kr'>
                                            <Binding Path="HeatCostNormal" />
                                            <Binding Path="HeatCostOptimized" />
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                                <TextBlock Margin="5" VerticalAlignment="Center">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat= '{}{0} kr    {1} kr'>
                                            <Binding Path="ElectricityCostNormal" />
                                            <Binding Path="ElectricityCostOptimized" />
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                                <TextBlock Margin="5" VerticalAlignment="Center">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat= '{}{0} kr    {1} kr'>
                                            <Binding Path="ElectricitySalesNormal" />
                                            <Binding Path="ElectricitySalesOptimized" />
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </UniformGrid>
                            <Button Grid.Row="0" Grid.Column="3" Background="Transparent" HorizontalAlignment="Right" Click="OpenEditUnitMenu">
                                <TextBlock Text="&#xf304;" FontFamily="{StaticResource FontAwesome}" FontSize="20"/>
                            </Button>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        <Button x:Name ="AddButton" Theme="{StaticResource ConfirmButton}" Content="Add production unit" HorizontalAlignment="Left" Click="OpenAddUnitMenu" Margin="20 10"/>
    </StackPanel>

</UserControl>