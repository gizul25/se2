<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.Avalonia"
    xmlns:vm="using:HeatItOn.ViewModels"
    x:Class="HeatItOn.Views.OverviewPage"
    x:DataType="vm:OverviewViewModel"
    Background="#F6F7F9">

<UserControl.Styles>
    <Style Selector="TextBlock">
        <Setter Property="Foreground" Value="Black"/>
    </Style>
    <!-- Sam ComboBox -->
<Style Selector="ComboBox">
    <Setter Property="Background" Value="#F1F3F5"/>
    <Setter Property="Foreground" Value="#333"/>
    <Setter Property="BorderBrush" Value="#D0D5DD"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="6"/>
</Style>

<!-- TO JEST KLUCZOWE -->
<!-- Tło dropdowna -->
<Style Selector="ComboBox /template/ Popup Border">
    <Setter Property="Background" Value="White"/>
    <Setter Property="BorderBrush" Value="#D0D5DD"/>
    <Setter Property="BorderThickness" Value="1"/>
</Style>

<!-- Itemy -->
<Style Selector="ComboBoxItem">
    <Setter Property="Background" Value="White"/>
    <Setter Property="Foreground" Value="#333"/>
</Style>

<Style Selector="ComboBoxItem:pointerover">
    <Setter Property="Background" Value="#F1F3F5"/>
</Style>

<Style Selector="ComboBoxItem:selected">
    <Setter Property="Background" Value="#E9ECEF"/>
</Style>
</UserControl.Styles>

<Grid ColumnDefinitions="220,*" RowDefinitions="Auto,*">

    <!-- SIDEBAR -->
    <Border Background="#F0F0F0" Padding="20" Grid.RowSpan="2">
        <StackPanel Spacing="20">

            <TextBlock Text="HeatItOn"
                       FontSize="22"
                       FontWeight="Bold"/>

            <StackPanel Spacing="10">

                <Border Background="#E4E4E4"
                        Padding="12"
                        CornerRadius="6">
                    <TextBlock Text="Scenario 1"/>
                </Border>

                <Border Padding="12">
                    <TextBlock Text="Scenario 2"/>
                </Border>

            </StackPanel>

        </StackPanel>
    </Border>

    <!-- TOP BAR -->
    <Border Grid.Column="1"
            Background="White"
            Padding="15"
            BorderBrush="#DDDDDD"
            BorderThickness="0,0,0,1">

        <Grid ColumnDefinitions="*,Auto">

            <TextBlock Text="{Binding Name}"
                       FontSize="28"
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>

            <ComboBox Grid.Column="1"
                    Width="150"
                    ItemsSource="{Binding Periods}"
                    SelectedItem="{Binding SelectedPeriod}"
                    DisplayMemberBinding="{Binding}"
                    Foreground="#333"/>


        </Grid>

    </Border>
    <!-- NAVIGATION TABS -->
    <Border Grid.Row="1"
            Grid.Column="1"
            Background="White"
            Padding="10 5"
            BorderBrush="#DDDDDD"
            BorderThickness="0,0,0,1">

        <StackPanel Orientation="Horizontal" Spacing="30">

            <TextBlock Text="Overview"
                    FontSize="18"
                    FontWeight="Bold"
                    Foreground="Black"/>

            <TextBlock Text="Optimizer"
                    FontSize="16"
                    Foreground="Black"/>

            <TextBlock Text="Production units"
                    FontSize="16"
                    Foreground="Black"/>

            <TextBlock Text="Configuration"
                    FontSize="16"
                    Foreground="Black"/>

        </StackPanel>

    </Border>

    <!-- MAIN -->
    <Grid Grid.Row="2"
          Grid.Column="1"
          Margin="20 40 20 20"
          RowSpacing="20"
          ColumnSpacing="20"
          RowDefinitions="*,*"
          ColumnDefinitions="*,*">

        <!-- HEAT -->
        <Border Background="White"
                BorderBrush="#DDDDDD"
                BorderThickness="1"
                CornerRadius="6"
                Padding="15">

            <Grid RowDefinitions="Auto,*">

                <TextBlock Text="Heat demand and production"
                           FontWeight="Bold"
                           Margin="0 0 0 10"/>

                <lvc:CartesianChart Grid.Row="1"
                                    Series="{Binding HeatSeries}"
                                    XAxes="{Binding XAxes}"
                                    YAxes="{Binding YAxes}"
                                    LegendPosition="Top"
                                    LegendTextPaint="Black"
                                    Background="White"/>

            </Grid>

        </Border>

        <!-- ELECTRICITY -->
        <Border Grid.Column="1"
                Background="White"
                BorderBrush="#DDDDDD"
                BorderThickness="1"
                CornerRadius="6"
                Padding="15">

            <Grid RowDefinitions="Auto,*">

                <TextBlock Text="Electricity consumption and production"
                           FontWeight="Bold"
                           Margin="0 0 0 10"/>

                <lvc:CartesianChart Grid.Row="1"
                                    Series="{Binding ElectricitySeries}"
                                    XAxes="{Binding XAxes}"
                                    YAxes="{Binding YAxes}"
                                    LegendPosition="Top"
                                    LegendTextPaint="Black"
                                    Background="White"/>

            </Grid>

        </Border>

        <!-- PRICES -->
        <Border Grid.Row="1"
                Background="White"
                BorderBrush="#DDDDDD"
                BorderThickness="1"
                CornerRadius="6"
                Padding="15">

            <Grid RowDefinitions="Auto,*">

                <TextBlock Text="Gas and electricity prices"
                           FontWeight="Bold"
                           Margin="0 0 0 10"/>

                <lvc:CartesianChart Grid.Row="1"
                                    Series="{Binding PriceSeries}"
                                    XAxes="{Binding XAxes}"
                                    YAxes="{Binding YAxes}"
                                    LegendPosition="Top"
                                    LegendTextPaint="Black"
                                    Background="White"/>

            </Grid>

        </Border>

        <!-- EXPENSES -->
        <Border Grid.Row="1"
                Grid.Column="1"
                Background="White"
                BorderBrush="#DDDDDD"
                BorderThickness="1"
                CornerRadius="6"
                Padding="15">

            <Grid RowDefinitions="Auto,*">

                <TextBlock Text="Expenses and profits"
                           FontWeight="Bold"
                           Margin="0 0 0 10"/>

                <lvc:CartesianChart Grid.Row="1"
                                    Series="{Binding ExpenseSeries}"
                                    XAxes="{Binding XAxes}"
                                    YAxes="{Binding YAxes}"
                                    LegendPosition="Top"
                                    LegendTextPaint="Black"
                                    Background="White"/>

            </Grid>

        </Border>

    </Grid>

</Grid>

</UserControl>